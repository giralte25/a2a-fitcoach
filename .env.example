# =====================================================================
# Configuración del modelo de lenguaje (elige UNA de las dos opciones)
# =====================================================================

# --- Opción A: OpenAI (por defecto) ---
OPENAI_API_KEY=sk-tu-api-key
OPENAI_CHAT_MODEL_ID=gpt-4o-mini

# --- Opción B: Azure OpenAI ---
# Si defines AZURE_OPENAI_ENDPOINT, el servidor usará Azure OpenAI en lugar de OpenAI.
# AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
# AZURE_OPENAI_API_KEY=tu-api-key-azure
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21

# =====================================================================
# Cliente A2A
# =====================================================================
# URL del servidor A2A de FitCoach (debe coincidir con --host/--port del servidor)
A2A_AGENT_HOST=http://localhost:5005/
